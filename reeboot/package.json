{
  "name": "reeboot",
  "version": "1.3.4",
  "description": "Personal AI agent running locally, reachable via WhatsApp, Signal, or WebChat",
  "author": "Bogdan Nenu",
  "license": "MIT",
  "type": "module",
  "bin": {
    "reeboot": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./channels": "./dist/channels/interface.js"
  },
  "files": [
    "dist/",
    "extensions/",
    "skills/",
    "templates/",
    "container/",
    "webchat/"
  ],
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "ai",
    "agent",
    "whatsapp",
    "signal",
    "personal-ai",
    "llm"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "check": "npm run build && npm run test:run"
  },
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "@mariozechner/pi-coding-agent": "0.62.0",
    "@mozilla/readability": "^0.5.0",
    "@types/ws": "^8.18.1",
    "@whiskeysockets/baileys": "6.7.21",
    "better-sqlite3": "^11.6.0",
    "commander": "^12.1.0",
    "cron-parser": "^4.9.0",
    "drizzle-kit": "^0.20.0",
    "drizzle-orm": "^0.31.0",
    "fastify": "^5.0.0",
    "inquirer": "^12.0.0",
    "linkedom": "^0.16.11",
    "nanoid": "^5.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.19.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}
