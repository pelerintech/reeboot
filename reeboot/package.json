{
  "name": "reeboot",
  "version": "0.0.1",
  "description": "Personal AI agent running locally, reachable via WhatsApp, Signal, or WebChat",
  "type": "module",
  "bin": {
    "reeboot": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./channels": {
      "import": "./dist/channels/interface.js"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "@mariozechner/pi-coding-agent": "latest",
    "@whiskeysockets/baileys": "6.7.21",
    "better-sqlite3": "^11.6.0",
    "commander": "^12.1.0",
    "drizzle-kit": "^0.20.0",
    "drizzle-orm": "^0.31.0",
    "fastify": "^5.0.0",
    "inquirer": "^12.0.0",
    "nanoid": "^5.0.0",
    "node-cron": "^4.2.1",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}
