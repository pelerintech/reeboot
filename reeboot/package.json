{
  "name": "reeboot",
  "version": "2.2.0",
  "description": "Personal AI agent running locally, reachable via WhatsApp, Signal, or WebChat",
  "author": "Bogdan Nenu",
  "license": "MIT",
  "type": "module",
  "bin": {
    "reeboot": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./channels": "./dist/channels/interface.js"
  },
  "files": [
    "dist/",
    "extensions/",
    "skills/",
    "templates/",
    "container/",
    "webchat/"
  ],
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "ai",
    "agent",
    "whatsapp",
    "signal",
    "personal-ai",
    "llm"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "check": "npm run build && npm run test:run"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@earendil-works/pi-coding-agent": "0.75.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@types/ws": "^8.18.1",
    "@whiskeysockets/baileys": "6.7.21",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "cron-parser": "^5.5.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.0",
    "@hono/node-server": "^1.19.14",
    "@hono/node-ws": "^1.3.1",
    "inquirer": "^13.4.3",
    "linkedom": "^0.18.12",
    "nanoid": "^5.0.0",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qrcode-terminal": "^0.12.0",
    "sqlite-vec": "^0.1.9",
    "typebox": "^1.1.38",
    "ws": "^8.20.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.19.41",
    "@types/pdf-parse": "^1.1.5",
    "@types/which": "^3.0.4",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^1.6.1"
  }
}
